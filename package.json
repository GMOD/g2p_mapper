{
  "name": "g2p_mapper",
  "description": "Map genome to protein coordinates and back",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/g2p_mapper.git"
  },
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "import": "./esm/index.js"
    },
    "require": {
      "require": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "esm",
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf dist esm",
    "format": "prettier --write .",
    "prebuild": "yarn clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "build": "yarn build:esm && yarn build:es5",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "yarn lint && yarn test --run && yarn build",
    "postversion": "git push --follow-tags"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
