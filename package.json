{
  "name": "g2p_mapper",
  "description": "Map genome to protein coordinates and back",
  "version": "2.1.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/g2p_mapper.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "import": "./esm/index.js",
    "require": "./dist/index.js"
  },
  "files": [
    "src",
    "esm",
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "clean": "rimraf dist esm",
    "format": "prettier --write .",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json",
    "prebuild": "pnpm clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "pnpm lint && pnpm typecheck && pnpm test --run && pnpm build",
    "postversion": "git push --follow-tags",
    "build": "pnpm build:esm && pnpm build:es5"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.4",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.17.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "bioinformatics"
  ],
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com"
  }
}
